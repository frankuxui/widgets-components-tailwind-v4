<Expo>
  <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="food">
    <svg
      viewBox="0 0 64 64"
      xmlns="http://www.w3.org/2000/svg"
      class="w-12 h-12"
      xml:space="preserve"
      style="fill-rule:evenodd;clip-rule:evenodd;stroke-linecap:round;stroke-linejoin:round;stroke-miterlimit:2"
    >
      <path style="fill:none" d="M0 0h64v64H0z"></path>
      <path
        d="M24 37h5M39.5 37H47a2 2 0 0 0 2-2v-3H15v3a2 2 0 0 0 2 2h1M18 37v2.002C18 46.733 24.267 53 31.998 53H32c3.713 0 7.274-1.475 9.899-4.101A13.996 13.996 0 0 0 46 39v-2M32 47v9M20.371 47l-3.041 9M43.629 47l3.041 9"
        stroke="currentColor"
        stroke-width="2px"
        fill="none"
      >
      </path>
      <path
        d="M31.669 23.118s-.695-2.299-4.46-3.872c-3.766-1.574-6.708 2.638-3.882 7.695 3.476 6.219 17.383 6.661 19.99 1.564 1.091-2.132.235-4.167.235-4.167-1.3-4.712-6.646-10.271-14.489-4.175"
        stroke="currentColor"
        stroke-width="2px"
        fill="none"
      >
      </path>
      <path
        d="M20.677 26.735c-1.123.883-1.567 1.222-1.852 1.386a.316.316 0 0 0-.475.322c.045.436.463 1.828 2.081.7 2.039-1.424 4.899.069 4.899.069M23.907 19.246l-5.761-4.239a1.021 1.021 0 0 0-1.329.101l-.001.001a.827.827 0 0 0 .017 1.189l5.085 4.792M42.295 10.6V8M26.655 10.6V8M37.382 10.6V8M21.742 10.6V8M13 32h38"
        stroke="currentColor"
        stroke-width="2px"
        fill="none"
      >
      </path>
    </svg>
  </article>

  <article class="border rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="food">
    <div class="w-full flex items-center justify-between gap-6">
      <header class="flex items-center gap-4">
        <svg
          viewBox="0 0 64 64"
          xmlns="http://www.w3.org/2000/svg"
          class="w-12 h-12"
          xml:space="preserve"
          style="fill-rule:evenodd;clip-rule:evenodd;stroke-linecap:round;stroke-linejoin:round;stroke-miterlimit:2"
        >
          <path style="fill:none" d="M0 0h64v64H0z"></path>
          <path
            d="M24 37h5M39.5 37H47a2 2 0 0 0 2-2v-3H15v3a2 2 0 0 0 2 2h1M18 37v2.002C18 46.733 24.267 53 31.998 53H32c3.713 0 7.274-1.475 9.899-4.101A13.996 13.996 0 0 0 46 39v-2M32 47v9M20.371 47l-3.041 9M43.629 47l3.041 9"
            stroke="currentColor"
            stroke-width="2px"
            fill="none"
          >
          </path>
          <path
            d="M31.669 23.118s-.695-2.299-4.46-3.872c-3.766-1.574-6.708 2.638-3.882 7.695 3.476 6.219 17.383 6.661 19.99 1.564 1.091-2.132.235-4.167.235-4.167-1.3-4.712-6.646-10.271-14.489-4.175"
            stroke="currentColor"
            stroke-width="2px"
            fill="none"
          >
          </path>
          <path
            d="M20.677 26.735c-1.123.883-1.567 1.222-1.852 1.386a.316.316 0 0 0-.475.322c.045.436.463 1.828 2.081.7 2.039-1.424 4.899.069 4.899.069M23.907 19.246l-5.761-4.239a1.021 1.021 0 0 0-1.329.101l-.001.001a.827.827 0 0 0 .017 1.189l5.085 4.792M42.295 10.6V8M26.655 10.6V8M37.382 10.6V8M21.742 10.6V8M13 32h38"
            stroke="currentColor"
            stroke-width="2px"
            fill="none"
          >
          </path>
        </svg>
        <div class="flex-auto">
          <span class="text-foreground/70">Chicken Shop</span>
          <h2 class="text-sm font-medium block">Grilled Chicken Salad</h2>
        </div>
      </header>
      <div class="relative group">
        <div
          class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2
           opacity-0 invisible
           transition-all duration-200
           group-hover:opacity-100 group-hover:visible
           z-50 font-medium text-xs px-3 py-1 rounded
           bg-foreground text-background"
        >
          Llamar
        </div>
        <button class="inline-flex items-center justify-center w-9 h-9
           rounded-full transition-colors duration-200
           focus:ring-2 focus:ring-primary
           hover:bg-foreground/5">
          <span class="material-symbols-rounded material-symbols-lg material-symbols-weight-300"> phone_enabled </span>
        </button>
      </div>
    </div>
  </article>

  <article class="border break-inside rounded-xl mb-3 text-xs grid grid-cols-12 border-border bg-background text-foreground" data-filter="food">
    <div class="p-3 col-span-3">
      <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" style="fill-rule:evenodd;clip-rule:evenodd;stroke-linecap:round;stroke-linejoin:round;stroke-miterlimit:2"
        ><path style="fill:none" d="M0 0h64v64H0z"></path><path
          d="M54.257 49.395a3.117 3.117 0 0 1-1.546.41h-5.217c-.945 0-1.838.429-2.429 1.165l-.723.901a3.112 3.112 0 0 1-2.428 1.165H22.086a3.112 3.112 0 0 1-2.428-1.165l-.723-.901a3.115 3.115 0 0 0-2.429-1.165h-5.217a3.117 3.117 0 0 1-1.546-.41L4 46.112h56l-5.743 3.283z"
          style="fill:none;stroke:currentColor;stroke-width:2px"></path><path
          d="M57 46.051c0 .081-50 .081-50 0 0-13.798 11.202-25 25-25s25 11.202 25 25z"
          style="fill:none;stroke:currentColor;stroke-width:2px"></path><path
          d="M13 46.066c0-3.34.864-6.48 2.38-9.209M20.294 31.104a19.018 19.018 0 0 1 3.97-2.395M32 20.869v-4M37 16.869H27M10.704 18.869s1.226-2.87-.334-6.214M53.296 18.869s-1.226-2.87.334-6.214M20.285 12.655s1.227-2.871-.334-6.215M43.715 12.655s-1.227-2.871.334-6.215"
          style="fill:none;stroke:currentColor;stroke-width:2px"></path></svg
      >
    </div>
    <div class="flex-1 flex flex-col items-start col-span-9 p-3 h-full border-l border-border">
      <p>Book your chicken salad today!</p>
      <div class="inline-flex items-center gap-2">
        <h2 class="text-sm font-medium">Taking Orders Now</h2>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-4 h-4"
          ><path
            fill="currentColor"
            d="m10.6 13.8l-2.15-2.15q-.275-.275-.7-.275t-.7.275t-.275.7t.275.7L9.9 15.9q.3.3.7.3t.7-.3l5.65-5.65q.275-.275.275-.7t-.275-.7t-.7-.275t-.7.275zM12 22q-2.075 0-3.9-.788t-3.175-2.137T2.788 15.9T2 12t.788-3.9t2.137-3.175T8.1 2.788T12 2t3.9.788t3.175 2.137T21.213 8.1T22 12t-.788 3.9t-2.137 3.175t-3.175 2.138T12 22"
          ></path></svg
        >
      </div>
    </div>
  </article>

  <article class="relative border break-inside rounded-xl mb-3 text-xs overflow-hidden s grid grid-cols-12 border-border bg-background text-foreground" data-filter="food">
    <div class="absolute bottom-0 left-0 w-full h-1 bg-foreground/10">
      <div class="h-1 bg-blue-600" style="width: 70%"></div>
    </div>
    <div class="p-3 col-span-3 flex items-center justify-center bg-foreground/2">
      <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" style="fill-rule:evenodd;clip-rule:evenodd;stroke-linecap:round;stroke-linejoin:round;stroke-miterlimit:2"
        ><path style="fill:none" d="M0 0h64v64H0z"></path><path
          d="M54.448 33a1.335 1.335 0 0 1 1.322 1.534l-.726 4.839A16 16 0 0 1 39.221 53H24.779A16 16 0 0 1 8.956 39.373l-.726-4.839A1.335 1.335 0 0 1 9.552 33h44.896z"
          style="fill:none;stroke:currentColor;stroke-width:2px"></path><path
          d="M47.5 45.284a15.105 15.105 0 0 1-9.6 3.432M43 52.503V57H21v-4.497M12.3 33a10.161 10.161 0 0 1 3.085-2.524 5.391 5.391 0 0 1 5.667-6.547 6.986 6.986 0 0 1 5.941-2.013c1.295-6.811 8.282-6.624 11.959-3.805 4.507.19 4.917 2.734 4.917 2.734a5.003 5.003 0 0 1 3.88 6.49c.505.472.961.994 1.362 1.558A5.01 5.01 0 0 1 52.941 33M26.5 28.5l-1-.5M42.5 29l.5-.5M15.444 20.109s-2.036-1.336-.627-3.838c2.195-3.898-.941-5.256-.941-5.256M51.373 20.109s2.037-1.336.627-3.838c-2.195-3.898.941-5.256.941-5.256M25.347 14.573s-2.036-1.335-.627-3.838c2.195-3.897-.941-5.256-.941-5.256M41.47 14.573s2.037-1.335.627-3.838c-2.195-3.897.941-5.256.941-5.256"
          style="fill:none;stroke:currentColor;stroke-width:2px"></path></svg
      >
    </div>
    <div class="flex-1 flex flex-col items-start col-span-9 p-3 h-full border-l gap-1.5 border-border">
      <p class="text-foreground/70">Your order is being prepared. Thank you for your patience!</p>
      <h2 class="text-sm font-medium">Your Order is 70% Ready</h2>
    </div>
  </article>
  <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="food"></article>
  <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="food"></article>
  <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="food"></article>
  <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="food"></article>
  <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="food"></article>
  <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="food"></article>
  <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="food"></article>
  <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="food"></article>
  <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="food"></article>
  <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="food"></article>
  <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="food"></article>
  <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="food"></article>

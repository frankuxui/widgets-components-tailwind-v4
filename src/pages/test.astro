---
import Expo from "@/layouts/Expo.astro"
---

<Expo>
  <section class="break-inside columns-2 items-start gap-3">
    <article class="border break-inside rounded-xl group overflow-hidden text-xs mb-3 p-3 border-border bg-background text-foreground" data-filter="shopping">...</article>
    <article class="border break-inside rounded-xl group overflow-hidden text-xs mb-3 p-3 border-border bg-background text-foreground" data-filter="shopping">...</article>
    <article class="border break-inside rounded-xl group overflow-hidden text-xs mb-3 p-3 border-border bg-background text-foreground" data-filter="shopping">...</article>
    <article class="border break-inside rounded-xl group overflow-hidden text-xs mb-3 p-3 border-border bg-background text-foreground" data-filter="shopping">...</article>
  </section>

  <article class="border break-inside rounded-xl group overflow-hidden text-xs mb-3 p-3 border-border bg-background text-foreground" data-filter="shopping">...</article>
  <article class="border break-inside rounded-xl group overflow-hidden text-xs mb-3 p-3 border-border bg-background text-foreground" data-filter="shopping">...</article>
  <article class="border break-inside rounded-xl group overflow-hidden text-xs mb-3 p-3 border-border bg-background text-foreground" data-filter="shopping">...</article>

  <article class="border break-inside rounded-xl overflow-hidden mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
    <header class="flex items-center justify-between gap-3 border-b border-dashed border-border p-4">
      <div>
        <p class="text-foreground/60">Boarding pass</p>
        <h2 class="text-lg font-semibold leading-tight">MAD -> LIS</h2>
      </div>
      <svg viewBox="0 0 48 48" class="size-10 text-sky-600" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M5 28l38-14-9 26-8-12-12 8 4-12z"></path>
      </svg>
    </header>
    <div class="grid grid-cols-3 gap-3 p-4">
      <div><span class="text-foreground/50">Gate</span><strong class="block text-sm">B12</strong></div>
      <div><span class="text-foreground/50">Seat</span><strong class="block text-sm">18A</strong></div>
      <div><span class="text-foreground/50">Time</span><strong class="block text-sm">14:30</strong></div>
    </div>
  </article>

  <article class="border break-inside rounded-xl p-4 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
    <header class="flex items-center justify-between">
      <div>
        <h2 class="text-sm font-semibold">Ruta del dia</h2>
        <p class="text-foreground/60">Centro historico a mirador</p>
      </div>
      <span class="rounded-full bg-emerald-500/10 px-2 py-1 text-emerald-600">4 paradas</span>
    </header>
    <svg viewBox="0 0 280 96" class="mt-4 h-24 w-full" fill="none">
      <path d="M24 72C70 18 108 84 150 42s72-12 106-30" stroke="currentColor" stroke-width="2" stroke-dasharray="5 5" class="text-foreground/35"></path>
      <circle cx="24" cy="72" r="7" class="fill-emerald-500"></circle>
      <circle cx="150" cy="42" r="7" class="fill-sky-500"></circle>
      <circle cx="256" cy="12" r="7" class="fill-rose-500"></circle>
    </svg>
  </article>

  <section class="break-inside columns-2 items-start gap-3">
    <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
      <div class="flex items-center justify-between">
        <svg viewBox="0 0 48 48" class="size-9 text-amber-600" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="12" y="14" width="24" height="26" rx="4"></rect>
          <path d="M18 14v-2a6 6 0 0112 0v2M18 22h12M18 30h8"></path>
        </svg>
        <strong>17.8 kg</strong>
      </div>
      <h2 class="mt-3 font-semibold text-sm">Equipaje</h2>
      <div class="mt-3 h-2 rounded-full bg-foreground/8">
        <div class="h-full w-[72%] rounded-full bg-amber-500"></div>
      </div>
      <p class="mt-2 text-foreground/60">Limite: 23 kg.</p>
    </article>

    <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
      <svg viewBox="0 0 48 48" class="size-8 text-blue-600" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M8 34h32M12 34l6-18h12l6 18M18 22h12M21 10h6"></path>
      </svg>
      <h2 class="mt-3 font-semibold text-sm">Puerta abierta</h2>
      <p class="mt-1 text-foreground/60">Embarque en 28 minutos.</p>
      <div class="mt-3 flex items-center justify-between rounded-lg bg-blue-500/10 p-2 text-blue-700 dark:text-blue-300">
        <span>Terminal 2</span><strong>Gate C7</strong>
      </div>
    </article>

    <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
      <div class="flex items-start justify-between">
        <div>
          <h2 class="font-semibold text-sm">Clima destino</h2>
          <p class="text-foreground/60">Roma, manana</p>
        </div>
        <svg viewBox="0 0 48 48" class="size-10 text-yellow-500" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="24" cy="24" r="8"></circle>
          <path d="M24 5v6M24 37v6M5 24h6M37 24h6M10 10l4 4M34 34l4 4M38 10l-4 4M14 34l-4 4"></path>
        </svg>
      </div>
      <strong class="mt-3 block text-3xl">27 C</strong>
      <p class="text-foreground/60">Ligero viento por la tarde.</p>
    </article>

    <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
      <h2 class="font-semibold text-sm">Presupuesto viaje</h2>
      <p class="mt-1 text-foreground/60">EUR 640 de EUR 900 usados</p>
      <svg viewBox="0 0 120 120" class="mx-auto mt-3 size-28 -rotate-90" fill="none">
        <circle cx="60" cy="60" r="44" stroke="currentColor" stroke-width="10" class="text-foreground/10"></circle>
        <circle cx="60" cy="60" r="44" stroke="currentColor" stroke-width="10" stroke-dasharray="276" stroke-dashoffset="80" class="text-teal-500"></circle>
      </svg>
    </article>
  </section>

  <article class="border break-inside rounded-xl p-4 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
    <header class="flex items-center justify-between">
      <div>
        <h2 class="text-sm font-semibold">Checklist express</h2>
        <p class="text-foreground/60">Antes de salir al aeropuerto</p>
      </div>
      <svg viewBox="0 0 48 48" class="size-9 text-lime-600" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 24l7 7 14-16"></path>
        <rect x="8" y="8" width="32" height="32" rx="8"></rect>
      </svg>
    </header>
    <div class="mt-4 grid gap-2">
      <p class="flex items-center justify-between"><span>Pasaporte</span><span class="text-lime-600">Listo</span></p>
      <p class="flex items-center justify-between"><span>Tarjeta SIM</span><span class="text-lime-600">Listo</span></p>
      <p class="flex items-center justify-between"><span>Seguro</span><span class="text-amber-600">Pendiente</span></p>
    </div>
  </article>

  <article class="border break-inside rounded-xl p-4 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-foreground/60">Hotel check-in</p>
        <h2 class="text-xl font-semibold">Habitacion 508</h2>
      </div>
      <svg viewBox="0 0 48 48" class="size-10 text-purple-600" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="17" cy="24" r="7"></circle>
        <path d="M24 24h18M32 24v6M38 24v5"></path>
      </svg>
    </div>
    <div class="mt-4 rounded-lg border border-dashed border-border p-3">
      <p class="flex justify-between"><span>Entrada</span><strong>15:00</strong></p>
      <p class="mt-2 flex justify-between"><span>Salida</span><strong>11:00</strong></p>
    </div>
  </article>

  <article class="relative border break-inside rounded-xl p-4 mb-3 text-xs overflow-hidden border-border bg-background text-foreground" data-filter="travel">
    <svg viewBox="0 0 220 120" class="absolute -right-8 -top-6 h-28 w-44 text-sky-500/15" fill="currentColor">
      <path d="M20 70c50-60 96 44 180-24v74H20z"></path>
    </svg>
    <div class="relative">
      <p class="text-foreground/60">Pasaporte digital</p>
      <h2 class="mt-1 text-lg font-semibold">ES-7842-TRV</h2>
      <div class="mt-4 grid grid-cols-2 gap-2">
        <span class="rounded bg-foreground/5 p-2">Visa OK</span>
        <span class="rounded bg-foreground/5 p-2">Seguro OK</span>
      </div>
    </div>
  </article>

  <article class="border break-inside rounded-xl p-4 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
    <header class="flex items-center gap-3">
      <svg viewBox="0 0 48 48" class="size-10 text-yellow-600" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M8 30h32l-4-12H12zM14 30v6M34 30v6M16 36h4M28 36h4M16 18l2-6h12l2 6"></path>
      </svg>
      <div>
        <h2 class="text-sm font-semibold">Taxi reservado</h2>
        <p class="text-foreground/60">Conductor: Leo Garcia</p>
      </div>
    </header>
    <div class="mt-4 flex items-center justify-between rounded-lg bg-foreground/5 p-3">
      <span>12 min</span><strong>EUR 18.50</strong>
    </div>
  </article>

  <section class="break-inside columns-2 items-start gap-3">
    <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
      <h2 class="font-semibold text-sm">Zonas horarias</h2>
      <div class="mt-3 grid gap-2">
        <p class="flex justify-between"><span>Madrid</span><strong>11:54</strong></p>
        <p class="flex justify-between"><span>Tokyo</span><strong>18:54</strong></p>
        <p class="flex justify-between"><span>NYC</span><strong>05:54</strong></p>
      </div>
    </article>

    <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-sm">Packing cubes</h2>
        <svg viewBox="0 0 48 48" class="size-8 text-rose-600" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="8" y="10" width="14" height="14" rx="3"></rect>
          <rect x="26" y="10" width="14" height="14" rx="3"></rect>
          <rect x="8" y="28" width="32" height="10" rx="3"></rect>
        </svg>
      </div>
      <div class="mt-3 flex gap-1">
        <span class="h-8 flex-1 rounded bg-rose-500/20"></span>
        <span class="h-8 flex-1 rounded bg-sky-500/20"></span>
        <span class="h-8 flex-1 rounded bg-lime-500/20"></span>
      </div>
      <p class="mt-2 text-foreground/60">Ropa, tech y aseo separados.</p>
    </article>

    <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
      <svg viewBox="0 0 48 48" class="size-8 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M24 6l15 6v10c0 10-6 17-15 20C15 39 9 32 9 22V12z"></path>
        <path d="M17 24l5 5 10-12"></path>
      </svg>
      <h2 class="mt-3 font-semibold text-sm">Seguro activo</h2>
      <p class="mt-1 text-foreground/60">Cobertura medica y equipaje.</p>
    </article>

    <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
      <h2 class="font-semibold text-sm">Visado</h2>
      <p class="mt-1 text-foreground/60">Solicitud en revision.</p>
      <div class="mt-3 flex items-center gap-2">
        <span class="size-3 rounded-full bg-emerald-500"></span>
        <span class="h-px flex-1 bg-emerald-500"></span>
        <span class="size-3 rounded-full bg-amber-500"></span>
        <span class="h-px flex-1 bg-foreground/15"></span>
        <span class="size-3 rounded-full bg-foreground/20"></span>
      </div>
    </article>
  </section>

  <article class="border break-inside rounded-xl p-4 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
    <header class="flex items-center justify-between">
      <div>
        <h2 class="text-sm font-semibold">Lounge airport</h2>
        <p class="text-foreground/60">Acceso incluido con tu plan</p>
      </div>
      <svg viewBox="0 0 48 48" class="size-10 text-cyan-600" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M10 30h28M14 30l-3 10M34 30l3 10M17 18h14a5 5 0 015 5v7H12v-7a5 5 0 015-5zM18 18V9h12v9"></path>
      </svg>
    </header>
    <div class="mt-4 flex items-center justify-between rounded-lg border border-border p-3">
      <span>Terminal 4S</span><strong>2 invitados</strong>
    </div>
  </article>

  <article class="break-inside rounded-xl p-4 mb-3 text-xs bg-gradient-to-br from-slate-950 to-sky-700 text-white" data-filter="travel">
    <p class="opacity-70">Cuenta atras</p>
    <h2 class="mt-1 text-3xl font-semibold">09 dias</h2>
    <p class="mt-2 opacity-80">para Islandia roadtrip.</p>
    <svg viewBox="0 0 220 54" class="mt-4 h-12 w-full" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M8 42c28-30 52-30 78 0s52 30 78 0 34-24 48-12" class="opacity-50"></path>
      <path d="M70 16l14 26h-28z" fill="currentColor" class="opacity-90"></path>
    </svg>
  </article>

  <article class="border break-inside rounded-xl p-4 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
    <header class="flex items-center justify-between">
      <h2 class="text-sm font-semibold">Gastos compartidos</h2>
      <span class="rounded-full bg-violet-500/10 px-2 py-1 text-violet-600">4 personas</span>
    </header>
    <div class="mt-4 grid gap-2">
      <p class="flex justify-between"><span>Ana pago hotel</span><strong>EUR 320</strong></p>
      <p class="flex justify-between"><span>Tu debes</span><strong>EUR 80</strong></p>
    </div>
    <button class="mt-4 inline-flex h-8 w-full items-center justify-center rounded-full bg-foreground text-background">Liquidar</button>
  </article>

  <article class="border break-inside rounded-xl p-4 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
    <div class="flex items-center justify-between gap-3">
      <div>
        <h2 class="text-sm font-semibold">Huella estimada</h2>
        <p class="text-foreground/60">Vuelo + hotel</p>
      </div>
      <svg viewBox="0 0 48 48" class="size-10 text-green-600" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M34 8C20 10 12 18 12 30c0 6 4 10 10 10 13 0 18-14 18-28V8z"></path>
        <path d="M14 36c6-12 13-18 24-24"></path>
      </svg>
    </div>
    <strong class="mt-4 block text-2xl">184 kg CO2</strong>
    <p class="text-foreground/60">Compensacion sugerida: EUR 7.40</p>
  </article>

  <article class="border break-inside rounded-xl p-4 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
    <header class="flex items-center justify-between">
      <div>
        <h2 class="text-sm font-semibold">Conexion tren</h2>
        <p class="text-foreground/60">Paris Nord -> Bruges</p>
      </div>
      <svg viewBox="0 0 48 48" class="size-10 text-red-600" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="12" y="6" width="24" height="28" rx="5"></rect>
        <path d="M17 14h14M17 22h14M18 34l-4 8M30 34l4 8M18 42h12"></path>
      </svg>
    </header>
    <div class="mt-4 flex items-center justify-between">
      <strong>08:16</strong>
      <span class="h-px flex-1 mx-3 bg-border"></span>
      <strong>10:02</strong>
    </div>
  </article>

  <article class="border break-inside rounded-xl p-4 mb-3 text-xs border-border bg-background text-foreground" data-filter="travel">
    <header class="flex items-center justify-between">
      <h2 class="text-sm font-semibold">Joyas locales</h2>
      <svg viewBox="0 0 48 48" class="size-9 text-pink-600" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M24 42s14-12 14-24A14 14 0 1010 18c0 12 14 24 14 24z"></path>
        <circle cx="24" cy="18" r="5"></circle>
      </svg>
    </header>
    <div class="mt-4 grid gap-2">
      <p class="rounded-lg bg-foreground/5 p-2">Cafe escondido en Alfama</p>
      <p class="rounded-lg bg-foreground/5 p-2">Mirador sin colas al atardecer</p>
      <p class="rounded-lg bg-foreground/5 p-2">Mercado local de ceramica</p>
    </div>
  </article>

  <article class="border break-inside rounded-xl p-4 mb-3 text-xs border-border bg-background text-foreground" data-filter="storage">
    <header class="flex items-center justify-between">
      <div>
        <h2 class="text-sm font-semibold">Cloud Vault</h2>
        <p class="text-foreground/60">2.4 TB usados de 4 TB</p>
      </div>
      <svg viewBox="0 0 48 48" class="size-10 text-sky-600" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M16 34H36a8 8 0 0 0 0-16 12 12 0 0 0-23-3A9 9 0 0 0 16 34z"></path>
      </svg>
    </header>
    <div class="mt-4 h-3 rounded-full bg-foreground/8 p-0.5">
      <div class="h-full w-[60%] rounded-full bg-sky-500"></div>
    </div>
    <p class="mt-2 text-foreground/60">Sincronizacion estable.</p>
  </article>

  <article class="border break-inside rounded-xl p-4 mb-3 text-xs border-border bg-background text-foreground" data-filter="multimedia">
    <header class="flex items-center justify-between">
      <div>
        <h2 class="text-sm font-semibold">Now playing</h2>
        <p class="text-foreground/60">Midnight City Radio</p>
      </div>
      <button class="size-10 rounded-full inline-flex items-center justify-center bg-foreground text-background">
        <span class="material-symbols-rounded material-symbols-weight-300">pause</span>
      </button>
    </header>
    <div class="mt-4 flex h-12 items-end gap-1">
      <span class="h-5 flex-1 rounded bg-fuchsia-500/40"></span>
      <span class="h-10 flex-1 rounded bg-fuchsia-500"></span>
      <span class="h-7 flex-1 rounded bg-fuchsia-500/60"></span>
      <span class="h-12 flex-1 rounded bg-fuchsia-500"></span>
      <span class="h-6 flex-1 rounded bg-fuchsia-500/40"></span>
      <span class="h-9 flex-1 rounded bg-fuchsia-500/70"></span>
    </div>
  </article>

  <article class="border break-inside rounded-xl p-4 mb-3 text-xs border-border bg-background text-foreground" data-filter="food">
    <div class="flex items-start justify-between gap-3">
      <div>
        <p class="text-foreground/60">Meal prep</p>
        <h2 class="text-xl font-semibold">5 bowls listos</h2>
      </div>
      <svg viewBox="0 0 48 48" class="size-10 text-emerald-600" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 24h30a14 14 0 0 1-14 14h-2A14 14 0 0 1 9 24z"></path>
        <path d="M15 24c2-8 16-8 18 0M18 14c0-4 4-4 4-8M28 14c0-4 4-4 4-8"></path>
      </svg>
    </div>
    <div class="mt-4 grid grid-cols-5 gap-1">
      <span class="h-2 rounded bg-emerald-500"></span>
      <span class="h-2 rounded bg-emerald-500"></span>
      <span class="h-2 rounded bg-emerald-500"></span>
      <span class="h-2 rounded bg-emerald-500"></span>
      <span class="h-2 rounded bg-foreground/10"></span>
    </div>
    <p class="mt-2 text-foreground/60">4 dias cubiertos.</p>
  </article>

  <section class="break-inside columns-2 items-start gap-3">
    <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="storage">
      <div class="flex items-center justify-between">
        <svg viewBox="0 0 48 48" class="size-9 text-violet-600" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="8" y="10" width="32" height="28" rx="5"></rect>
          <path d="M14 18h20M14 26h12M32 30l4 4 6-8"></path>
        </svg>
        <span class="rounded-full bg-violet-500/10 px-2 py-1 text-violet-600">Auto</span>
      </div>
      <h2 class="mt-3 font-semibold text-sm">Backup nocturno</h2>
      <p class="mt-1 text-foreground/60">Proxima copia a las 02:00.</p>
    </article>

    <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="storage">
      <h2 class="font-semibold text-sm">Archivos grandes</h2>
      <p class="mt-1 text-foreground/60">Detectados para limpiar.</p>
      <div class="mt-3 grid gap-2">
        <p class="flex justify-between rounded bg-foreground/5 p-2"><span>Video.mov</span><strong>8.2 GB</strong></p>
        <p class="flex justify-between rounded bg-foreground/5 p-2"><span>Backup.zip</span><strong>5.1 GB</strong></p>
      </div>
    </article>

    <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="multimedia">
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-sm">Podcast queue</h2>
        <span class="material-symbols-rounded material-symbols-weight-300">graphic_eq</span>
      </div>
      <div class="mt-3 grid gap-2">
        <p class="rounded bg-foreground/5 p-2">Diseno invisible · 24 min</p>
        <p class="rounded bg-foreground/5 p-2">Producto y cafe · 41 min</p>
      </div>
    </article>

    <article class="border break-inside rounded-xl p-3 mb-3 text-xs border-border bg-background text-foreground" data-filter="food">
      <div class="flex items-center justify-between">
        <h2 class="font-semibold text-sm">Despensa</h2>
        <span class="rounded-full bg-amber-500/10 px-2 py-1 text-amber-600">Bajo</span>
      </div>
      <div class="mt-3 grid gap-2">
        <p class="flex justify-between"><span>Avena</span><strong>12%</strong></p>
        <p class="flex justify-between"><span>Arroz</span><strong>28%</strong></p>
        <p class="flex justify-between"><span>Cafe</span><strong>9%</strong></p>
      </div>
    </article>
  </section>

  <article class="border break-inside rounded-xl overflow-hidden mb-3 text-xs border-border bg-background text-foreground" data-filter="storage">
    <header class="flex items-center justify-between p-4">
